# Copy this file to .env.local and fill in real values. Never commit .env.local.

# OpenAI API key (server-side only — never exposed to the browser)
OPENAI_API_KEY=sk-...

# Model id. Swap freely without code changes.
# gpt-4o-mini works on any account. gpt-5-* models require OpenAI org ID verification.
OPENAI_MODEL=gpt-4o-mini

# --- Email capture destination (optional, wire up later) ---
# Resend (https://resend.com) for emailing leads to Zak.
# RESEND_API_KEY=
# LEAD_NOTIFY_TO=zak@example.com
# LEAD_NOTIFY_FROM=onboarding@resend.dev
