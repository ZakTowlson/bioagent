# Copy this file to .env.local and fill in real values. Never commit .env.local.

# OpenAI API key (server-side only — never exposed to the browser)
OPENAI_API_KEY=sk-...

# Model id. Swap freely without code changes.
# gpt-4o follows the question style best. gpt-5-* models require OpenAI org ID verification.
OPENAI_MODEL=gpt-4o

# Calendly (or any booking) link, shown as a CTA after the full reflection.
# Public — safe to expose to the browser.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/intro-call

# --- Lead storage: Google Sheet via an Apps Script web app ---
# Paste the deployed Apps Script web app URL here (see README).
GOOGLE_SHEET_WEBHOOK_URL=

# --- Optional: also email each lead to Zak via Resend ---
# RESEND_API_KEY=
# LEAD_NOTIFY_TO=zak@example.com
# LEAD_NOTIFY_FROM=onboarding@resend.dev
